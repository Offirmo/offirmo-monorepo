{
	"name": "@monorepo-private/digital-hoarder",
	"version": "0.0.1",
	"private": true,
	"sideEffects": false,
	"type": "module",
	"exports": {
		".": "./module/src/index.ts"
	},
	"source": "module/src/index.ts",
	"peerDependencies": {
		"tslib": "^2"
	},
	"dependencies": {
		"@monorepo-private/assert": "*",
		"@monorepo-private/normalize-string": "*"
	},
	"scripts": {
		"clean": "echo todo",
		"check--ts": "echo \"@monorepo-private/digital-hoarder\" && tsc --noEmit",
		"check--ts--watch": "tsc --noEmit --watch",
		"dev": "run-s check--ts--watch",
		"check": "run-s check--ts",
		"_start:vite:sandbox": "vite --port 1981 --strictPort --logLevel info --open module/~~sandbox/index.html",
		"_start:parcel:sandbox": "parcel serve module/~~sandbox/index.html --port 1981 --lazy --no-autoinstall",
		"sandboxp": "npm-run-all clean --parallel _start:parcel:sandbox",
		"sandbox": "npm-run-all clean --parallel _start:vite:sandbox"
	},
	"devDependencies": {
		"@monorepo-private/config--typescript": "*",
		"@monorepo-private/monorepo-scripts": "*",
		"@monorepo-private/ts--types": "*",
		"@monorepo-private/ts--types--web": "*",
		"@offirmo/unit-test-toolbox": "^9",
		"npm-run-all": "^4",
		"tslib": "^2",
		"typescript": "^6"
	}
}
