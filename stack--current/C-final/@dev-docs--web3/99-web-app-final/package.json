{
	"name": "@dev-docs--web3/web-app-final",
	"version": "0.0.1",
	"private": true,
	"sideEffects": true,
	"type": "module",
	"exports": {
		".": "./module/src/serve-me/index.html"
	},
	"source": "module/src/serve-me/index.html",
	"dependencies": {
		"@monorepo-private/assert": "*",
		"tslib": "^2"
	},
	"scripts": {
		"_clean--pkg": "monorepo-script--clean-package …cache …dist",
		"clean": "npm-run-all _clean--pkg",
		"check--ts": "echo \"@dev-docs--web3/web-app-final\" && tsc --noEmit",
		"check--ts--watch": "tsc --noEmit --watch",
		"dev": "run-s clean check--ts--watch",
		"check": "run-s check--ts",
		"_start:vite:main": "vite --port 1981 --strictPort --logLevel info --open module/src/serve-me/index.html",
		"_start:parcel:main": "parcel serve module/src/serve-me/index.html --port 1981 --lazy --no-autoinstall",
		"startp": "npm-run-all clean --parallel _start:parcel:main",
		"start": "npm-run-all clean --parallel _start:vite:main"
	},
	"devDependencies": {
		"@monorepo-private/config--typescript": "*",
		"@monorepo-private/monorepo-scripts": "*",
		"@monorepo-private/storypad": "*",
		"@monorepo-private/toolbox--parcel": "*",
		"@monorepo-private/toolbox--vite": "*",
		"@offirmo/unit-test-toolbox": "^9",
		"npm-run-all": "^4",
		"typescript": "^6"
	}
}
