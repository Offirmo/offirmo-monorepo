{
	"name": "@monorepo-private/react--error-boundary",
	"description": "Generic error boundary for React, with a fallback UI and logging",
	"version": "0.0.1",
	"private": true,
	"sideEffects": false,
	"type": "module",
	"exports": {
		".": "./module/src/index.ts"
	},
	"source": "module/src/index.ts",
	"peerDependencies": {
		"@monorepo-private/soft-execution-context": "*",
		"react": "^19",
		"tslib": "^2"
	},
	"dependencies": {
		"@monorepo-private/assert": "*",
		"@monorepo-private/utils--async": "*",
		"memoize-one": "^6"
	},
	"scripts": {
		"_clean--pkg": "monorepo-script--clean-package …cache …dist",
		"clean": "npm-run-all _clean--pkg",
		"check--ts": "echo \"@monorepo-private/react--error-boundary\" && tsc --noEmit",
		"check--ts--watch": "tsc --noEmit --watch",
		"dev": "run-s clean check--ts--watch",
		"check": "run-s check--ts",
		"_start:parcel:storypad": "parcel serve module/__fixtures/storypad/index.html --port 1981 --lazy --no-autoinstall",
		"_start:vite:storypad": "vite --port 1981 --strictPort --logLevel info --open module/__fixtures/storypad/index.html",
		"storiesp": "npm-run-all clean --parallel _start:parcel:storypad",
		"stories": "npm-run-all clean --parallel _start:vite:storypad",
		"_start:parcel:demo": "parcel serve module/~~demo/index.html --port 1981 --lazy --no-autoinstall",
		"_start:vite:demo": "vite --port 1981 --strictPort --logLevel info --open module/~~demo/index.html",
		"demop": "npm-run-all clean --parallel _start:parcel:demo",
		"demo": "npm-run-all clean --parallel _start:vite:demo"
	},
	"devDependencies": {
		"@monorepo-private/config--typescript": "*",
		"@monorepo-private/monorepo-scripts": "*",
		"@monorepo-private/soft-execution-context": "*",
		"@monorepo-private/storypad": "*",
		"@monorepo-private/toolbox--parcel": "*",
		"@monorepo-private/toolbox--vite": "*",
		"@offirmo/unit-test-toolbox": "^9",
		"@types/react": "^19",
		"npm-run-all": "^4",
		"react": "^19",
		"react-dom": "^19",
		"tslib": "^2",
		"typescript": "^6"
	}
}
