{
	"name": "@monorepo-private/css--foundation",
	"description": "A thin layer of universal, semantically great, strongly recommended modern CSS",
	"version": "0.0.1",
	"private": true,
	"sideEffects": true,
	"type": "module",
	"exports": {
		".": "./module/src/index.css"
	},
	"source": "module/src/index.css",
	"peerDependencies": {
		"tslib": "^2"
	},
	"dependencies": {
		"@monorepo-private/assert": "*"
	},
	"scripts": {
		"_clean--pkg": "monorepo-script--clean-package …cache …dist",
		"clean": "npm-run-all _clean--pkg",
		"check--ts": "echo \"@monorepo-private/css--foundation\" && tsc --noEmit",
		"check--ts--watch": "tsc --noEmit --watch",
		"dev": "run-s clean check--ts--watch",
		"check": "run-s check--ts",
		"_start:parcel:storypad": "parcel serve module/__fixtures/storypad/index.html --port 1981 --lazy --no-autoinstall",
		"_start:vite:storypad": "vite --port 1981 --strictPort --logLevel info --open module/__fixtures/storypad/index.html",
		"stories": "npm-run-all clean --parallel _start:parcel:storypad",
		"_start:parcel:demo": "parcel serve module/__fixtures/wc-kitchen-sink/demo.html --port 1981 --lazy --no-autoinstall",
		"_start:vite:demo": "vite --port 1981 --strictPort --logLevel info --open module/__fixtures/wc-kitchen-sink/demo.html",
		"demo": "npm-run-all clean --parallel _start:parcel:demo",
		"_start:vite:sandbox": "vite --port 1981 --strictPort --logLevel info --open module/~~sandbox/index.html",
		"_start:parcel:sandbox": "parcel serve module/~~sandbox/index.html --port 1981 --lazy --no-autoinstall",
		"sandbox": "npm-run-all clean --parallel _start:parcel:sandbox",
		"_build:bundle": "node --experimental-strip-types ./++gen/build--bundle/index.ts",
		"build": "run-s _build:bundle"
	},
	"devDependencies": {
		"@monorepo-private/config--typescript": "*",
		"@monorepo-private/css--reset": "*",
		"@monorepo-private/monorepo-scripts": "*",
		"@monorepo-private/storypad": "*",
		"@monorepo-private/toolbox--parcel": "*",
		"@monorepo-private/toolbox--vite": "*",
		"@offirmo/unit-test-toolbox": "^9",
		"@types/node": "^24",
		"lightningcss": "^1",
		"npm-run-all": "^4",
		"tslib": "^2",
		"typescript": "^6"
	}
}
