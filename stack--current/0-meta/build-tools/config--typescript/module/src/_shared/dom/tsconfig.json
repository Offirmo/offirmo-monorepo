{
  "$schema": "https://json.schemastore.org/tsconfig",

  /* Some common **technical choices** and **intelligent defaults**,
   * based on our specific needs and experience.
   * Do NOT set "strict"ness related settings here, see the other bases.
   * REMINDER: those are defaults, packages are free to override if specific needs!
   */

  "extends": ["../isomorphic/tsconfig.json"],

  "TODOcompilerOptions": {
    /* Highest target declared in TypeScript = 2024 (as of 2025/08)
     * (we trust the transpiler to handle any "next" JS feature)
     */
    "target": "ES2024",

    /* We use ESM + a bundler
     */
    "module": "ES2022",
    "moduleResolution": "bundler",

    "lib": [
      /* obviously */
      "DOM",
      /* we trust the transpiler to handle any "next" JS feature */
      "ESNext"
    ],

    /* Intelligent default:
     * most packages are libs = always use preserve.
     * Apps should override this to their preferred transform
     * https://legacy.reactjs.org/blog/2020/09/22/introducing-the-new-jsx-transform.html
     */
    "jsx": "preserve"
  }
}
