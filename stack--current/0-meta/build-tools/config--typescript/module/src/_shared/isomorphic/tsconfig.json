{
  "$schema": "https://json.schemastore.org/tsconfig",
  // https://www.typescriptlang.org/tsconfig/

  /* Some common **technical choices** and **intelligent defaults**,
   * based on our specific needs and experience.
   * Do NOT set "strict"ness related settings here, see the other bases.
   * REMINDER: those are defaults, packages are free to override if specific needs!
   */

  "TODOcompilerOptions": {
    // ordered following the TS doc https://www.typescriptlang.org/tsconfig/#compiler-options

    /*** Type Checking ***/

    /*** Modules ***/

    /* To enable direct node execution.
     * https://devblogs.microsoft.com/typescript/announcing-typescript-5-7/#path-rewriting-for-relative-paths%60
     */
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true,
    /* Tech choice: strictest to catch issues.null
     * This adds friction to any non-ESM modules, prompting for finding a replacement.
     */
    "allowUmdGlobalAccess": false,
    /* Tech choice: We strive for pure ESM
     */
    "module": "ES2022",
    "noUncheckedSideEffectImports": true,

    /*** Emit ***/

    /* Tech choice: we don't export small public packages,
     * so we'd rather have a single shared instance of the TS helpers to save bundle size.
     * This requires the "tslib" package to be
     * - declared as peer+dev by packages
     * - declared as dep in apps
     */
    "importHelpers": true,
    "noEmitHelpers": true,
    /* Intelligent default: */
    "newLine": "lf",
    /* Intelligent default: As of 2025/08 we don't pre-bundle our packages. (may change in the future)
     */
    "noEmit": true,

    /*** Interop Constraints ***/

    /* Tech choice: To prevent from using non-standard TypeScript features such as TS enums,
     * especially to enable direct node invocation
     * https://www.typescriptlang.org/tsconfig/#erasableSyntaxOnly
     */
    "erasableSyntaxOnly": true,
    /* Tech choice: safety against accidental casing issues,
     * https://www.typescriptlang.org/tsconfig/#forceConsistentCasingInFileNames
     */
    "forceConsistentCasingInFileNames": true,
    /* Help some bundlers (ex. Parcel https://parceljs.org/languages/typescript/#isolatedmodules)
     * Should also greatly help our type-check speed issues due to relying on implicit return types.
     * = So better having it from the beginning rather than having to backport later.
     * https://www.typescriptlang.org/tsconfig#isolatedModules
     */
    "isolatedModules": true,
    /* Also to enable direct node invocation.
     * https://www.typescriptlang.org/tsconfig/#verbatimModuleSyntax
     */
    "verbatimModuleSyntax": true,

    /*** Language and Environment ***/

    /* Experimental feature = avoid it by default
     */
    "emitDecoratorMetadata": false,
    "experimentalDecorators": false,
    /* intentionally DON'T set "jsx" => use the DOM base instead!
     */
    /* TEST
     */
    "moduleDetection": "force"
  },
  "include": [
    "don't bother, this is NOT inherited!",
    "ref: https://www.typescriptlang.org/tsconfig/#extends"
  ]
}
